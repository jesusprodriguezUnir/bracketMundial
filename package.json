{
  "name": "bracketmundial",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "icons": "node scripts/generate-icons.mjs",
    "photos": "node scripts/fetch-squad-assets.mjs",
    "assets:report": "node scripts/fetch-squad-assets.mjs --report",
    "pages": "tsx scripts/generate-pages.mjs",
    "prebuild": "tsx scripts/generate-pages.mjs && node scripts/generate-icons.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "news": "node scripts/generate-news.mjs",
    "odds": "tsx scripts/generate-odds.mjs",
    "test": "vitest run",
    "cap:sync": "npm run build && npx cap sync",
    "android": "npm run cap:sync && npx cap open android",
    "ios": "npm run cap:sync && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@supabase/supabase-js": "^2.49.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "exceljs": "^4.4.0",
    "html-to-image": "^1.11.13",
    "lit": "^3.3.2",
    "workbox-window": "^7.4.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@playwright/test": "^1.60.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6"
  }
}
