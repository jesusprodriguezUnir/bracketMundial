# Supabase — copia este archivo como .env y rellena los valores
# Encuéntralos en: tu proyecto Supabase → Settings → API

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# UUID del usuario administrador (Supabase Auth → Users → tu usuario)
# Solo este usuario puede publicar resultados oficiales
VITE_ADMIN_UID=

# ── Fotos de jugadores y entrenadores (scripts/fetch-squad-assets.mjs) ────────
# Sin keys el script usa TheSportsDB + Wikipedia como fallback (cobertura parcial).
# Con keys mejora la cobertura en selecciones menores (JOR, IRQ, CUW, HAI...).

# API-Football via RapidAPI — plan free: 100 req/día
# 1. Regístrate en https://rapidapi.com
# 2. Busca "API-Football" y suscríbete al plan Basic (gratuito)
# 3. Copia la key desde la pestaña "Header Parameters" → X-RapidAPI-Key
API_FOOTBALL_KEY=

# football-data.org — plan free (requiere registro)
# 1. Regístrate en https://www.football-data.org/client/register
# 2. La key llega por email (campo "API-Token" en tu perfil)
# Nota: se usa principalmente en --verify-data para cruzar datos de plantilla
FOOTBALL_DATA_KEY=

# ── Probabilidad 1X2 por partido (scripts/generate-odds.mjs) ──────────────────
# Sin key el script escribe un feed vacío y la UI simplemente oculta el bloque.
# Plan free: ~500 req/mes. 1 req/ejecución × 2 crons/día ≈ 60 req/mes.
# Las odds de fase de grupos aparecen días antes del torneo (junio 2026).
#
# 1. Regístrate en https://the-odds-api.com
# 2. Copia tu API key desde el dashboard
# 3. Añade el secreto ODDS_API_KEY en GitHub → Settings → Secrets → Actions
ODDS_API_KEY=
